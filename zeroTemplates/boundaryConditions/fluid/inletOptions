FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "templates";
    object      inletOptions;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

flowSpecification
{
    fixedPressure
    {
        U
        {
            type        pressureInletVelocity;
            value       ${:VALUE.U};
        }
        p
        {
            type        fixedValue;
            value       ${:VALUE.p};
        }
    }
    fixedVelocity
    {
        U
        {
            type        fixedValue;
            value       ${:VALUE.U};
        }
        p
        {
            type        zeroGradient;
        }
    }
    srfFreestream
    {
        Urel
        {
            type        SRFFreestreamVelocity;
            UInf        ${:VALUE.UInf};
            relative    false;
            value       ${:VALUE.U};
        }
        U
        {
            type        SRFFreestreamVelocity;
            UInf        ${:VALUE.UInf};
            relative    false;
            value       ${:VALUE.U};
        }
        p
        {
            type        freestreamPressure;
            // freestreamPressure sets the in/out split from (U & nf)/mag(U). In SRFSimpleFoam the
            // absolute U is constructed (U = Urel + omega x r) and on the srfFreestream inflow faces
            // it is exactly zero (still air: -omega x r cancels omega x r). The single-precision ESI
            // build divides by mag(U) without a vSmall guard -> 0/0 sigFpe once U is reconstructed
            // (~iteration 2). Key off Urel instead: it is ~INLET_MAG (never zero) at the boundary and
            // is the field that actually defines the rotating-frame flux direction.
            U           Urel;
            freestreamValue ${:VALUE.p};
            value       ${:VALUE.p};
        }
    }
}

