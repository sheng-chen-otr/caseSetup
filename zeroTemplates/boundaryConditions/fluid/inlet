FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "templates";
    object      inlet;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

subSonic
{
    nut
    {
        type        calculated;
        value       ${:VALUE.nut};
    }
    k
    {
        type        fixedValue;
        value       ${:VALUE.k};
    }
    epsilon
    {
        type        fixedValue;
        value       ${:VALUE.epsilon};
    }
    omega
    {
        type        fixedValue;
        value       ${:VALUE.omega};
    }
    
    nuTilda
    {
        type        fixedValue;
        value       ${:VALUE.nuTilda};
    }

    OPTIONS         (flowSpecification);
}


freestream
{
    nut
    {
        type        calculated;
        value       ${:VALUE.nut};
    }
    k
    {
        type        inletOutlet;
        inletValue  ${:VALUE.k};
        value       ${:VALUE.k};
    }
    epsilon
    {
        type        inletOutlet;
        inletValue  ${:VALUE.epsilon};
        value       ${:VALUE.epsilon};
    }
    omega
    {
        type        inletOutlet;
        inletValue  ${:VALUE.omega};
        value       ${:VALUE.omega};
    }

    nuTilda
    {
        type        inletOutlet;
        inletValue  ${:VALUE.nuTilda};
        value       ${:VALUE.nuTilda};
    }

    OPTIONS         (flowSpecification);
}


